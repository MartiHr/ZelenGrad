{
  "name": "zelengrad",
  "version": "0.1.0",
  "private": true,
  "description": "ZelenGrad full-stack TypeScript monorepo for municipal green asset management.",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "docker compose up --build",
    "dev:detached": "docker compose up --build -d",
    "down": "docker compose down",
    "backend:dev": "npm run dev --workspace backend",
    "frontend:dev": "npm run dev --workspace frontend",
    "prisma:generate": "npm run prisma:generate --workspace backend",
    "prisma:migrate": "npm run prisma:migrate --workspace backend",
    "prisma:seed": "npm run prisma:seed --workspace backend"
  },
  "engines": {
    "node": ">=20"
  }
}
